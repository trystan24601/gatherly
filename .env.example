# -----------------------------------------------
# Gatherly — local development environment
# Copy this file to .env and fill in real values
# for any environment that is not docker-compose.
# -----------------------------------------------

# ---- DynamoDB ----
# Point at DynamoDB Local when running outside Docker.
# Leave unset (or remove) to use the real AWS endpoint.
DYNAMODB_ENDPOINT=http://localhost:8000
DYNAMODB_TABLE_NAME=gatherly-local

# ---- AWS (used by the DynamoDB SDK) ----
AWS_REGION=eu-west-2
# Dummy credentials for DynamoDB Local — replace with real values for cloud.
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# ---- Server ----
NODE_ENV=development
PORT=3001

# ---- Session ----
# Sessions are server-side only: the cookie contains a plain UUID and is
# validated by a DynamoDB lookup on every request. No HMAC signing is used
# because the session secret adds no security when the token is already
# validated against the database. SESSION_SECRET is intentionally absent.

# ---- Email (SMTP) ----
# Locally, point at Mailhog (docker-compose starts it on port 1025).
SMTP_HOST=localhost
SMTP_PORT=1025
# Set to "true" to use TLS (leave "false" for Mailhog).
SMTP_SECURE=false
EMAIL_FROM=noreply@gatherlywork.com

# ---- SQS (password-reset queue) ----
# When SQS_QUEUE_URL is empty the backend falls back to direct SMTP via
# nodemailer (suitable for local development with Mailhog).
# Set to a real SQS queue URL in staging/production.
SQS_QUEUE_URL=
