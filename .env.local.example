# =============================================================================
# Gatherly — Local Development Environment Variables
# Copy to .env.local and fill in values. Never commit .env.local.
# =============================================================================

# --- AWS (local dev uses DynamoDB Local, not real AWS) ---
AWS_REGION=eu-west-2
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# --- DynamoDB ---
DYNAMODB_ENDPOINT=http://localhost:8000
DYNAMODB_TABLE_NAME=gatherly-local

# --- Auth / Sessions ---
# 32+ byte random hex string. Local dev only — never reuse in prod.
SESSION_SECRET=local-dev-secret-change-me-32-chars-min

# --- Email (MailHog for local dev) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@gatherlywork.com

# --- API ---
PORT=3001
NODE_ENV=development

# --- Frontend (Vite) ---
VITE_API_BASE_URL=http://localhost:3001

# --- SQS (optional for local dev — backend can skip SQS or use ElasticMQ) ---
SQS_QUEUE_URL=

# --- Seed data (local dev only) ---
SEED_USER_PASSWORD=TestPassword123!

# --- E2E Tests ---
E2E_BASE_URL=http://localhost:5173
E2E_API_URL=http://localhost:3001

# =============================================================================
# Production secrets are stored in AWS Secrets Manager:
#   gatherly/staging/session-secret
#   gatherly/staging/ses-smtp-password
#   gatherly/prod/session-secret
#   gatherly/prod/ses-smtp-password
# =============================================================================
